# Backend base URL.
#   Local dev (empty = use Vite proxy → http://localhost:8000, no CORS):
#     VITE_API_BASE_URL=
#   Production / external host:
#     VITE_API_BASE_URL=https://airwatch-bq-backend.onrender.com
VITE_API_BASE_URL=

# Polling interval for /sensor/current (ms).
VITE_POLLING_INTERVAL_MS=60000

# Set to "true" to mock the API in the browser (offline demo).
VITE_USE_MSW=false

# When MSW is on, this fraction of requests will randomly fail (0–1).
VITE_MSW_FAIL_RATE=0
