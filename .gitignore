.env
.env.*
!.env.example

# --- Logs --------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- Test / coverage --------------------------------------------------------
coverage/
.nyc_output/
.vitest-cache/

# --- Editors / IDEs ---------------------------------------------------------
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# --- OS junk ----------------------------------------------------------------
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# --- Tooling caches ---------------------------------------------------------
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
.turbo/

# --- Local tooling / agents -------------------------------------------------
.claude/
.playwright-mcp/

# --- Misc -------------------------------------------------------------------
*.tsbuildinfo
