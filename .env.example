# =============================================================================
# AirWatch BQ — Frontend env template
# =============================================================================
# Copia este archivo a `.env` (NO se sube al repo) y ajusta valores si necesitas.
#   cp .env.example .env
#
# Las variables `VITE_*` se inlinen en el bundle del navegador — NO pongas
# secretos aquí.
# =============================================================================

# -----------------------------------------------------------------------------
# Backend base URL.
# -----------------------------------------------------------------------------
# Dejar VACÍO es el valor correcto en local + Docker: el cliente HTTP usa
# rutas relativas (/api/...) y el proxy (Vite en dev / nginx en Docker) las
# enruta al backend real. Así no hay CORS y puedes cambiar el backend sin
# rebuildear el bundle.
#
#   Local dev (Vite proxy → http://localhost:8000):
#     VITE_API_BASE_URL=
#
#   Despliegue estático (Vercel/Netlify) apuntando al backend público:
#     VITE_API_BASE_URL=https://airwatch-bq-backend.onrender.com
VITE_API_BASE_URL=

# -----------------------------------------------------------------------------
# Cada cuánto refresca /sensor/current (en milisegundos).
# -----------------------------------------------------------------------------
VITE_POLLING_INTERVAL_MS=60000

# -----------------------------------------------------------------------------
# Mock Service Worker — demo offline sin backend.
# Si está en "true", TODAS las llamadas /api/* son respondidas por MSW desde
# datos sintéticos. Útil para diseñar UI o demos en avión.
# -----------------------------------------------------------------------------
VITE_USE_MSW=false

# -----------------------------------------------------------------------------
# Con MSW activo, fracción 0–1 de peticiones que fallan al azar.
# Útil para probar manualmente estados de error y skeletons.
# -----------------------------------------------------------------------------
VITE_MSW_FAIL_RATE=0
